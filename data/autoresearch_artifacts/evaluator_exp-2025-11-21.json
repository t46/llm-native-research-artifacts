  "failure_cases": [
    "Mediator Blocking (33% of failures): Pruning ablations of mediating components",
    "Bottleneck Blocking (27% of failures): Pruning critical bottleneck components",
    "Sibling Independence (20% of failures): Pruning causally independent but experimentally valuable components",
    "Terminal Node Blocking (13% of failures): Pruning leaf components that affect outcomes",
    "Downstream Selection Bias (7% of failures): Pruning based on irrelevant downstream dependencies"
  ],
  "key_findings": [
    "D-separation is inappropriate for experimental design tasks",
    "96% of ablation candidates are pruned by d-separation with 68% false positive rate",
    "Causal independence does not imply experimental redundancy",
    "Five distinct failure modes explain all observed d-separation failures",
    "Perfect precision (100%) demonstrates other CausalAP components work correctly"
  ],
